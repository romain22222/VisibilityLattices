    }
    \draw[-{Stealth[length=3mm]}=black] (-1,0) -- (-1,7);
    \draw decorate [decoration={crosses,transform={rotate=45},shape size=1.5mm,segment length=7.8pt}] {(-1,1) -- (-1,6)};
    \foreach \y in {0,1,...,10} {
        \node at (-1.5,\y/2+1) {\scriptsize\y};
